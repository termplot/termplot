---
import Base from "../layouts/Base.astro";
---

<Base
  title="TermPlot — Plotly plots in your terminal"
  description="TermPlot renders Plotly plots inside your terminal as real images. Scaffold placeholder home page."
>
  <section class="mx-auto max-w-5xl px-6 py-24">
    <h1 class="font-display text-4xl font-bold tracking-tight sm:text-5xl">
      <span class="text-primary">Term</span><span class="text-accent">Plot</span>
    </h1>
    <p class="mt-4 max-w-xl text-lg text-muted">
      Plotly plots, rendered as real images inside your terminal. The full site
      lands as this issue's experiments progress — this is the scaffold.
    </p>
  </section>
</Base>
