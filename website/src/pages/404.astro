---
import Base from "../layouts/Base.astro";
---

<Base
  title="404 — TermPlot"
  description="No such plot: the page you asked for is not in the registry."
>
  <section class="mx-auto max-w-5xl px-6 py-24 text-center">
    <img
      src="/images/termplot-mark-192.png"
      alt=""
      width="96"
      height="96"
      class="mx-auto mb-8 opacity-60"
    />
    <h1 class="font-display text-3xl font-bold tracking-tight">
      unknown plot: <span class="font-mono text-plot">404</span>
    </h1>
    <p class="mt-4 text-muted">
      No such plot — the page you asked for is not in the registry.
    </p>
    <div class="mt-8 flex justify-center gap-4">
      <a
        href="/"
        class="rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-background transition-opacity hover:opacity-85"
      >Home</a>
      <a
        href="/docs/"
        class="rounded-lg border border-border px-5 py-2.5 text-sm font-semibold transition-colors hover:border-muted"
      >Docs</a>
    </div>
  </section>
</Base>
