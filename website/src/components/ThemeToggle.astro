<button
  id="theme-toggle"
  type="button"
  aria-label="Theme: system — click for light"
  class="rounded-lg border border-border p-2 text-muted transition-colors hover:text-foreground"
>
  <svg
    class="toggle-system h-4 w-4"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <rect x="2" y="3" width="20" height="14" rx="2"></rect>
    <path d="M8 21h8m-4-4v4"></path>
  </svg>
  <svg
    class="toggle-sun h-4 w-4"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
    ></path>
  </svg>
  <svg
    class="toggle-moon h-4 w-4"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  const ORDER = ["system", "light", "dark"] as const;
  const root = document.documentElement;
  const media = matchMedia("(prefers-color-scheme: dark)");
  const toggle = document.getElementById("theme-toggle");

  const label = () => {
    const current = root.dataset.themeSetting ?? "system";
    const next = ORDER[(ORDER.indexOf(current as any) + 1) % ORDER.length];
    toggle?.setAttribute("aria-label", `Theme: ${current} — click for ${next}`);
    toggle?.setAttribute("title", `Theme: ${current} — click for ${next}`);
  };
  label();

  toggle?.addEventListener("click", () => {
    const current = root.dataset.themeSetting ?? "system";
    const next = ORDER[(ORDER.indexOf(current as any) + 1) % ORDER.length];
    root.dataset.themeSetting = next;
    root.dataset.theme = next === "system"
      ? (media.matches ? "dark" : "light")
      : next;
    try {
      localStorage.setItem("theme", next);
    } catch {}
    label();
  });
</script>
